# API Configuration
POLYGON_API_KEY=pk_your_polygon_api_key_here

# Backend Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/sectors.db

# Cache
CACHE_TTL_HOURS=24

# Rate Limiting
POLYGON_RATE_LIMIT_REQUESTS=600
POLYGON_RATE_LIMIT_WINDOW_MS=60000

# CORS
CORS_ORIGIN=http://localhost:5173
