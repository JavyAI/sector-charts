# API Configuration
# POLYGON_API_KEY — reserved for future direct-Polygon integration (not currently required)
# POLYGON_API_KEY=pk_your_polygon_api_key_here

# Backend Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/sectors.db

# Cache
CACHE_TTL_HOURS=24

# Rate Limiting
POLYGON_RATE_LIMIT_REQUESTS=600
POLYGON_RATE_LIMIT_WINDOW_MS=60000

# CORS
CORS_ORIGIN=http://localhost:5173

# GitHub repo containing constituent data (private)
CONSTITUENTS_REPO=javyai/sector-data
CONSTITUENTS_FILE_PATH=constituents.csv
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ThetaData Terminal — shared Railway instance (also used by spy-fluid-sim + backfill_history.py).
# Override with http://127.0.0.1:25503 ONLY for explicit local dev sessions.
THETADATA_URL=https://theta-terminal-v3-production-132e.up.railway.app
